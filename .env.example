# ============================================================================
#  SP SMART SARL — Variables d'environnement (MODÈLE)
# ----------------------------------------------------------------------------
#  Copiez ce fichier en « .env.local » puis remplissez les valeurs réelles.
#  NE JAMAIS commiter « .env.local » sur Git (déjà ignoré).
#  Les variables NEXT_PUBLIC_* sont visibles côté navigateur : pas de secret.
# ============================================================================

# --- Sanity CMS -------------------------------------------------------------
# Identifiant du projet Sanity (créé sur https://www.sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID="votre_project_id"
# Jeu de données (généralement « production »)
NEXT_PUBLIC_SANITY_DATASET="production"
# Version de l'API Sanity (date figée, ne pas changer sans raison)
NEXT_PUBLIC_SANITY_API_VERSION="2024-01-01"
# Jeton de lecture côté serveur (Sanity > API > Tokens)
# SECRET — ne jamais exposer côté client
SANITY_API_READ_TOKEN="votre_token_lecture"
# Jeton d'ÉCRITURE — usages :
#   • Formulaires : devis / rendez-vous enregistrés dans Sanity
#   • Script d'import en masse : `npm run import-content`
#     (lit services-content.json et crée les services + FAQ d'un coup)
# SECRET — créer un token avec droits « Editor » dans Sanity > API > Tokens
SANITY_API_WRITE_TOKEN="votre_token_ecriture"
# Secret partagé pour le webhook de revalidation Sanity -> Next.js
SANITY_REVALIDATE_SECRET="chaine_aleatoire_longue_et_secrete"

# --- Resend (envoi des emails devis / contact) ------------------------------
RESEND_API_KEY="re_votre_cle_resend"
# Adresse expéditrice vérifiée dans Resend
RESEND_FROM_EMAIL="contact@spsmart.cm"
# Adresse qui reçoit les demandes de devis / rendez-vous
RESEND_TO_EMAIL="commercial@spsmart.cm"

# --- hCaptcha (anti-spam des formulaires) -----------------------------------
NEXT_PUBLIC_HCAPTCHA_SITE_KEY="votre_site_key_hcaptcha"
HCAPTCHA_SECRET_KEY="votre_secret_hcaptcha"

# --- Google Maps (carte de la page Contact) ---------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="votre_cle_google_maps"

# --- Analytics --------------------------------------------------------------
# Vercel Analytics s'active automatiquement au déploiement (aucune clé).
# Google Analytics (optionnel)
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# --- Site -------------------------------------------------------------------
# URL publique du site (utilisée pour le sitemap, l'Open Graph, le SEO)
NEXT_PUBLIC_SITE_URL="https://www.spsmart.cm"

# --- Module Billing — Supabase ----------------------------------------------
# Base de données transactionnelle (devis, factures…). Voir supabase/README.md.
# Récupérées dans Supabase > Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL="https://votre-projet.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="votre_anon_key"
# SECRET — clé service role, serveur uniquement (jamais exposée au navigateur)
SUPABASE_SERVICE_ROLE_KEY="votre_service_role_key"
